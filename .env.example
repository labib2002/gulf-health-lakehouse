# Copy to .env and adjust. Real .env is git-ignored.

# --- Postgres (Phase 1 / 3 / 6) ---
POSTGRES_USER=health
POSTGRES_PASSWORD=health
POSTGRES_DB=health
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- Data generator (Phase 0) ---
# Override config.yaml defaults from the environment if you want.
GEN_USERS=500
GEN_HISTORY_MONTHS=18
GEN_SEED=42

# --- BigQuery (Phase 5) ---
# Looks truncated as provided; verify before use. Leave blank to build offline.
BQ_PROJECT_ID=
BQ_DATASET=health_lakehouse
# Path (inside container) to a service-account JSON. Git-ignored.
GOOGLE_APPLICATION_CREDENTIALS=

# --- Kafka (Phase 6) ---
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
